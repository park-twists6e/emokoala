---
import Layout from "../../../layouts/Layout.astro";
import { categories } from "../../../data/categories";
import { projects } from "../../../data/projects";
import { slugify } from "../../../lib/slug";
import Lightbox from "../../../components/Lightbox.astro";
import About from "../../../components/About.astro";
import Footer from "../../../components/Footer.astro";
import { pathFinder } from "../../../lib/paths";

export function getStaticPaths() {
    const paths = [];

    for (const category of Object.values(categories)) {
        if (!category.enabled) continue;

        const categoryProjects = projects.filter(
            (project) =>
                project.enabled && project.categories.includes(category.id),
        );

        for (const project of categoryProjects) {
            paths.push({
                params: {
                    category: category.id,
                    project: slugify(project.title),
                },
                props: {
                    category,
                    project,
                },
            });
        }
    }

    return paths;
}

const { category, project } = Astro.props;

const relatedProjects = projects.filter(
    (item) =>
        item.enabled &&
        item.title !== project.title &&
        item.categories.includes(category.id),
);

const lightboxImages = [
    project.media.poster || project.media.hero,
    ...project.media.gallery,
].filter(Boolean);
---

<Layout title={`${project.title} | ${category.title}`}>
    <main class="container category-page">
        <a class="section-label" href={pathFinder(`/work/${category.id}`)}
            >←
            <!-- <span class="brand brand-with-mark">
                <img src="/brand/emokoala-logo.png" alt="" />
            </span> -->
            <!-- Back to my {category.title} work -->
            Back 
        </a>

        <header class="category-header">
            <p class="section-label">
                <span class="brand brand-with-mark">
                    <img src={pathFinder("/brand/emokoala-logo.png")} alt="" />
                </span>
                {category.title} Project
            </p>
            <h1>{project.title}</h1>
            <p>{project.description}</p>
        </header>

        <section class="featured-project single-project">
            <div
                class:list={{
                    "featured-media": true,
                    portrait: project.media.portrait,
                }}
            >
                {
                    project.media.type === "video" && project.media.video ? (
                        <div class="video-frame">
                            <video
                                class="portfolio-video"
                                controls={project.media.showControls}
                                poster={pathFinder(project.media.poster || project.media.hero)}
                                loop={project.media.loop}
                                autoplay={project.media.autoPlay}
                                muted={project.media.autoPlay}
                                playsinline
                            >
                                <source
                                    src={pathFinder(project.media.video)}
                                    type="video/mp4"
                                />
                            </video>

                            {!project.media.showControls && (
                                <button
                                    class="video-dock"
                                    aria-label="Play or Pause"
                                >
                                    {/* <img
                                        src="/brand/emokoala-logo.png"
                                        alt=""
                                        aria-hidden="true"
                                    /> */}

                                    <span class="video-icon">▶</span>
                                </button>
                            )}
                        </div>
                    ) : (
                        // <img src={project.media.poster} alt={project.title} />
                        // <img
                        //     class="zoomable"
                        //     src={project.media.poster}
                        //     alt={project.title}
                        //     data-lightbox={project.media.poster}
                        // />
                        <img
                            class="zoomable"
                            src={pathFinder(project.media.poster || project.media.hero)}
                            alt={project.title}
                            data-index="0"
                        />
                    )
                }
            </div>

            <div class="featured-info">
                <p class="section-label">Details</p>

                <div class="project-meta-inline">
                    <span>{project.role}</span>
                    <span>{project.year}</span>
                    <span>{project.software.join(", ")}</span>
                </div>
            </div>
        </section>

        {
            project.media.gallery.length > 0 && (
                <section class="category-gallery">
                    <div class="section-label">Gallery</div>

                    <div class="image-gallery">
                        {project.media.gallery.map((image, index) => (
                            <img
                                class="zoomable"
                                src={pathFinder(image)}
                                alt={project.title}
                                data-index={index + 1}
                            />
                        ))}
                    </div>
                </section>
            )
        }

        {
            relatedProjects.length > 0 && (
                <section class="category-gallery">
                    <div class="section-label">More {category.title}</div>

                    <div class="work-grid">
                        {relatedProjects.map((item) => (
                            <a
                                class="work-card"
                                href={pathFinder(`/work/${category.id}/${slugify(item.title)}`)}
                            >
                                <div class="work-thumb">
                                    <img
                                        src={pathFinder(item.media.hero)}
                                        alt={item.title}
                                    />
                                </div>

                                <h2>{item.title}</h2>
                                <p>{item.description}</p>
                            </a>
                        ))}
                    </div>
                </section>
            )
        }
    </main>
    <!-- <About /> -->

    <Footer />

    <Lightbox images={lightboxImages} />
    <script>
        document.querySelectorAll(".video-frame").forEach((frame) => {
            const video = frame.querySelector(
                "video",
            ) as HTMLVideoElement | null;
            const button = frame.querySelector(
                ".video-dock",
            ) as HTMLButtonElement | null;
            const icon = frame.querySelector(
                ".video-icon",
            ) as HTMLElement | null;

            if (!video) return;
            if (video.controls) return;
            if (!button || !icon) return;

            const safeVideo = video;
            const safeButton = button;
            const safeIcon = icon;

            function updateButton() {
                safeIcon.textContent = safeVideo.paused ? "▶" : "❚❚";
                safeButton.classList.toggle("video-playing", !safeVideo.paused);
            }

            function toggleVideo() {
                if (safeVideo.paused) {
                    safeVideo.play();
                } else {
                    safeVideo.pause();
                }
            }

            safeButton.addEventListener("click", (event) => {
                event.preventDefault();
                event.stopPropagation();
                toggleVideo();
            });

            safeVideo.addEventListener("click", toggleVideo);
            safeVideo.addEventListener("play", updateButton);
            safeVideo.addEventListener("pause", updateButton);
            safeVideo.addEventListener("ended", updateButton);

            updateButton();
        });
    </script>
</Layout>

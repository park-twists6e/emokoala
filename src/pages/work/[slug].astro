---
import Layout from "../../layouts/Layout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { categories } from "../../data/categories";
import { projects } from "../../data/projects";
import About from "../../components/About.astro";
import Footer from "../../components/Footer.astro";

export function getStaticPaths() {
    return Object.values(categories)
        .filter((category) => category.enabled)
        .map((category) => ({
            params: { slug: category.id },
            props: { category },
        }));
}

const { category } = Astro.props;

const categoryProjects = projects.filter(
    (project) => project.enabled && project.categories.includes(category.id),
);

const selectedProject = categoryProjects[0];
---

<Layout title={`${category.title} | Emokoala`}>
    <main class="container category-page">
        <a class="section-label" href="/#work"
            >←
            <!-- <span class="brand brand-with-mark">
                <img src="/brand/emokoala-logo.png" alt="" />
            </span> -->

            Back to Portfolio</a
        >

        <header class="category-header">
            <p class="section-label">
                <span class="brand brand-with-mark">
                    <img src="/brand/emokoala-logo.png" alt="" />
                </span>
                {category.title} Portfolio
            </p>
            <h1>{category.title}</h1>
            <p>{category.description}</p>
        </header>

        <!-- {
            selectedProject ? (
                <section class="featured-project">
                    <div class="featured-media">
                        {selectedProject.media.type === "video" &&
                        selectedProject.media.video ? (
                            <video
                                controls
                                poster={
                                    selectedProject.media.poster ||
                                    selectedProject.media.hero
                                }
                            >
                                <source
                                    src={selectedProject.media.video}
                                    type="video/mp4"
                                />
                            </video>
                        ) : (
                            <img
                                src={selectedProject.media.poster}
                                alt={selectedProject.title}
                            />
                        )}
                    </div>

                    <div class="featured-info">
                        <p class="section-label">{category.title}</p>
                        <h2>{selectedProject.title}</h2>
                        <p>{selectedProject.description}</p>

                        <div class="project-meta-inline">
                            <span>{selectedProject.role}</span>
                            <span>{selectedProject.year}</span>
                            <span>{selectedProject.software.join(", ")}</span>
                        </div>
                    </div>
                </section>
            ) : (
                <div class="empty-state">
                    <p>No projects added yet.</p>
                </div>
            )
        } -->

        {
            categoryProjects.length > 1 && (
                <section class="category-gallery">
                    <div class="section-label">{category.title}</div>

                    <div class="work-grid">
                        {categoryProjects.map((project) => (
                            // <ProjectCard project={project} />
                            <ProjectCard
                                project={project}
                                category={category}
                            />
                        ))}
                    </div>
                </section>
            )
        }
    </main>
    <!-- <About /> -->

    <Footer />
</Layout>

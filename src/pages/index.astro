---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import ProjectCard from "../components/ProjectCard.astro";
import FeaturedReel from "../components/FeaturedReel.astro";
import ProjectGrid from "../components/ProjectGrid.astro";
import { projects } from "../data/projects";
---

<Layout title="Emokoala">
	<main>
		<Hero />
		
		<FeaturedReel />

		<ProjectGrid projects={projects} />

		<section id="about" class="container about-section">
			<div>
				<p class="section-label">About</p>
				<h2>Animator, editor, and visual designer.</h2>
			</div>

			<p>
				Emokoala creates character-driven visual work across animation,
				editing, background art, and design. This portfolio highlights
				selected projects, process work, and finished pieces.
			</p>
		</section>

		<footer class="footer container">
			<p>© 2026 Emokoala</p>
			<a href="mailto:hello@example.com">Contact</a>
		</footer>
	</main>
</Layout>

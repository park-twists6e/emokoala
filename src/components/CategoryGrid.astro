---
import CategoryCard from "./CategoryCard.astro";
import { pathFinder } from "../lib/paths";

const { categories } = Astro.props;
---

<section id="work" class="container work-section">
    <br />
    <div class="section-label">
        <a class="brand brand-with-mark" href={pathFinder("/")}>
            <img src={pathFinder("/brand/emokoala-logo.png")} alt="" />
        </a>
        My Portfolio
    </div>

    <div class="work-grid">
        {
            categories.map((category: any) => (
                <CategoryCard category={category} />
            ))
        }
    </div>
</section>

---
import { slugify } from "../lib/slug";
import { pathFinder } from "../lib/paths";

const { project, category } = Astro.props;

const href = category ? pathFinder(`/work/${category.id}/${slugify(project.title)}`) : "#";
---

<a class="work-card" href={href}>
    <div class="work-thumb">
        <img src={pathFinder(project.media.hero)} alt={project.title} />
    </div>

    <h2>{project.title}</h2>
    <p>{project.description}</p>
</a>

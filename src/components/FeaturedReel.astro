---
import FeaturedVideo from "./FeaturedVideo.astro";
import { projects } from "../data/projects";
import { pathFinder } from "../lib/paths";

const featuredProject = projects.find(
    (project) => project.enabled && project.featured,
);
// console.log({featuredProject});
---

<section id="reel" class="container reel-section">

    {
        featuredProject ? (
            <div class="section-label">Featured Reel</div>
        
            <FeaturedVideo
                poster={pathFinder(featuredProject.media.poster || featuredProject.media.hero)}
                video={pathFinder(featuredProject.media.video)}
            />
        ) : (
            // <div class="empty-state">
                <p></p>
            // </div>
        )
    }
</section>

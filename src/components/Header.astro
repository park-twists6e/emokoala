---
const { profile } = Astro.props;
---

<header class="site-header">
    <a class="brand brand-with-mark" href="/">
        <img src="/brand/emokoala-logo.png" alt="" />
        <span>{profile.name}</span>
    </a>
    <nav class="nav">
        {profile.navigation.map((item) => <a href={item.href}>{item.title}</a>)}
    </nav>
</header>

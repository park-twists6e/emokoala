      />
    </a>
    <!-- {base}<br />{pathFinder("/brand/emokoala-logo.png")} -->

    <h1>
      <a class="" href="#work" aria-label="Scroll to featured work">
        <sub class="emo"><u>emo</u></sub><b class="koala"><i>koala</i></b> &nbsp;
      </a>
    </h1>

    <br />
    <p class="eyebrow">Animator • Editor • Illustrator</p>

    <!-- <p class="tagline"> -->
      <!-- Expressive stories through motion, editing, and visual design. -->
    <!-- </p> -->

    <a class="scroll-hint" href="#reel" aria-label="Scroll to featured reel"
      >↓</a
    >
  </div>

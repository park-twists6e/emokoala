---
import "../styles/global.css";
import Header from "../components/Header.astro";

interface Props {
	title?: string;
}

const { title = "Emokoala Portfolio" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
	</head>

	<body>
		<Header />

		<slot />
	</body>
</html>
